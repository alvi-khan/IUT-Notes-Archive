<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="JavaFX.JavaFXHome_Controller">
    <stylesheets>
        <URL value="@javafx.css" />
    </stylesheets>
   <children>
      <Button fx:id="exitButton" layoutX="466.0" layoutY="14.0" mnemonicParsing="false" onAction="#loadExitConfirm" prefHeight="50.0" prefWidth="100.0" text="Exit" textAlignment="CENTER">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button fx:id="nextButton" layoutX="466.0" layoutY="336.0" mnemonicParsing="false" onAction="#nextPage" text="Next Page" textAlignment="CENTER">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Label layoutX="238.0" layoutY="182.0" text="Home Page">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
